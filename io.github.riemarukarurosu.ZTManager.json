{
    "app-id": "io.github.riemarukarurosu.ZTManager",
    "runtime": "org.gnome.Platform",
    "runtime-version": "50",
    "sdk": "org.gnome.Sdk",
    "command": "ztmanager",
    "finish-args": [
        "--share=network",
        "--share=ipc",
        "--socket=fallback-x11",
        "--device=dri",
        "--socket=wayland",
        "--talk-name=org.freedesktop.Flatpak",
        "--socket=system-bus",
        "--talk-name=org.freedesktop.systemd1",
        "--filesystem=xdg-config/ztlib:create"
    ],
    "cleanup": [
        "/include",
        "/lib/pkgconfig",
        "/man",
        "/share/doc",
        "/share/gtk-doc",
        "/share/man",
        "/share/pkgconfig",
        "*.la",
        "*.a"
    ],
    "modules": [
        "python3-requests.json",
        "python3-psutil.json",
        "python3-pydbus.json",
        {
            "name": "ztmanager",
            "builddir": true,
            "buildsystem": "meson",
            "sources": [
                {
                    "type": "dir",
                    "path": "."
                }
            ],
            "config-opts": [
                "--libdir=lib"
            ]
        }
    ],
    "build-options": {
        "env": {}
    }
}