<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.riemarukarurosu.ZTManager</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>
  <name>ZT Manager</name>
  <summary>ZeroTier network management client for GNOME</summary>

  <description>
    <p>
      <em>This is a community package of ZT Manager and not officially supported by ZeroTier, Inc.</em>
    </p>
    <p>
      <em>Note: This application requires the 'zerotier-one' service to be installed and running on your host system.</em>
    </p>
    <p>
      ZT Manager is a modern GTK4/Libadwaita client for managing ZeroTier networks on Linux. 
      It provides a clean and intuitive interface that integrates perfectly with the GNOME desktop environment.
    </p>
    <p>Features:</p>
    <ul>
      <li>Join and leave networks with a single click.</li>
      <li>Automatic token detection in Host Mode.</li>
      <li>Manual Mode for remote controller connectivity.</li>
      <li>Detailed network information (IPs, MAC, Status).</li>
      <li>Real-time peer/node visualization.</li>
      <li>Auto-refreshing network status.</li>
    </ul>
  </description>

  <developer id="io.github.riemarukarurosu">
    <name>Riemaru Karurosu</name>
  </developer>

  <launchable type="desktop-id">io.github.riemarukarurosu.ZTManager.desktop</launchable>

  <screenshots>
    <screenshot type="default">
      <image>https://raw.githubusercontent.com/RiemaruKarurosu/ZT-Manager/main/screenshots/main.png</image>
      <caption>The main network list view.</caption>
    </screenshot>
  </screenshots>

  <url type="homepage">https://github.com/RiemaruKarurosu/ZT-Manager</url>
  <url type="bugtracker">https://github.com/RiemaruKarurosu/ZT-Manager/issues</url>
  <url type="vcs-browser">https://github.com/RiemaruKarurosu/ZT-Manager</url>

  <releases>
    <release version="2.0.2" date="2026-05-12">
      <description>
        <p>First stable release under the ZT Manager name:</p>
        <ul>
          <li>Rebranded to ZT Manager for better compliance.</li>
          <li>Fixed UI crashes in Peers window.</li>
          <li>Updated to GNOME 50 and GTK4.</li>
          <li>Full English and Spanish localization.</li>
        </ul>
      </description>
    </release>
    <release version="2.0.1-Beta" date="2026-05-12">
      <description>
        <p>Technical polish and internationalization:</p>
        <ul>
          <li>Added English and Spanish language support.</li>
          <li>Hardened Flatpak permissions for better security.</li>
          <li>Updated to GNOME 50 runtime.</li>
          <li>Host Mode is now opt-in by default.</li>
        </ul>
      </description>
    </release>
    <release version="2.0.0-BETA" date="2024-05-12">
      <description>
        <p>Major modernization update:</p>
        <ul>
          <li>Migrated to GTK4 and Libadwaita.</li>
          <li>Added auto-refreshing network status.</li>
          <li>New network details and peers visualization.</li>
          <li>Improved token security and persistence.</li>
        </ul>
      </description>
    </release>
  </releases>

  <content_rating type="oars-1.1" />
</component>
